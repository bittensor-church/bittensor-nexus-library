# Copy to: demos/cat-images/docker/.env.validator
# Then edit values before running:
#   docker compose -f docker-compose.validator.yaml --env-file .env.validator up --build

# Validator image/network
VALIDATOR_IMAGE=cat-validator:compose
VALIDATOR_DOCKER_NETWORK=cat-images-validator-net
VALIDATOR_DOCKER_SUBNET=172.30.0.0/24
VALIDATOR_CONTAINER_IP=172.30.0.10
PYLON_CONTAINER_IP=172.30.0.20

# Validator runtime
VALIDATOR_NETUID=2
VALIDATOR_REST_ENTRY_POINT_PORT=8081
VALIDATOR_MINER_CALLBACK_PORT=9091
VALIDATOR_OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
VALIDATOR_OPENROUTER_MODEL=google/gemini-2.5-flash-image
VALIDATOR_VALIDATION_PROMPT=
VALIDATOR_VALIDATION_OPENROUTER_TIMEOUT_SECONDS=120.0
VALIDATOR_VALIDATION_OPENROUTER_TEMPERATURE=0.0
VALIDATOR_S3_BUCKET=kuba-cat-images-bucket

# Pylon runtime
# Default for a host-run subtensor localnet. Override to `test` for testnet.
PYLON_BITTENSOR_NETWORK=http://host.docker.internal:9944
# JSON list of netuids for open-access recent-object caching (required by validator routing).
PYLON_RECENT_OBJECTS_NETUIDS=[2]
PYLON_OPEN_ACCESS_TOKEN=local-open-access-token
# Identity used by validator for weight writes.
PYLON_IDENTITIES=["validator"]
PYLON_ID_VALIDATOR_WALLET_NAME=some-wallet-name
PYLON_ID_VALIDATOR_HOTKEY_NAME=default
PYLON_ID_VALIDATOR_NETUID=2
PYLON_ID_VALIDATOR_TOKEN=replace-with-strong-shared-token
# This is passed to validator as the identity name used for identity API calls.
VALIDATOR_PYLON_IDENTITY_NAME=validator
PYLON_HOST_PORT=18000

# AWS/Boto credentials for validator
AWS_DEFAULT_REGION=us-east-1

# Required secrets passed at command runtime:
# VALIDATOR_OPENROUTER_API_KEY
# AWS_ACCESS_KEY_ID
# AWS_SECRET_ACCESS_KEY
# Optional at runtime:
# AWS_SESSION_TOKEN
