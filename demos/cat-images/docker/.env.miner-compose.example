# Copy to: cat-images/docker/.env.miner
# Then edit values before running:
#   ./run_miner.sh up

# Image/container/network
MINER_IMAGE=cat-miner:latest
MINER_CONTAINER_NAME=cat-miner
MINER_DOCKER_NETWORK=cat-images-validator-net
MINER_CONTAINER_IP=172.30.0.30

# Host/container port mapping
MINER_HOST_BIND_IP=127.0.0.1
MINER_HOST_PORT=9090
MINER_PORT=9090

# Wallet mount (used for axon updates; requires write access)
MINER_WALLET_DIR=${HOME}/.bittensor

# Required secret passed at command runtime:
# MINER_OPENROUTER_API_KEY

# Optional miner runtime
MINER_OPENROUTER_URL=https://openrouter.ai/api/v1/chat/completions
MINER_OPENROUTER_MODEL=google/gemini-2.5-flash-image
MINER_PATH=/process
# MINER_PROMPT=custom prompt text

# Optional axon updater
MINER_UPDATE_AXON=false
MINER_WALLET_NAME=default
MINER_HOTKEY_NAME=default
MINER_SUBTENSOR_NETWORK=finney
# MINER_NETUID=278
# MINER_EXTERNAL_IP=${MINER_CONTAINER_IP}
# MINER_EXTERNAL_PORT=${MINER_PORT}
# MINER_SERVE_INTERVAL=60
