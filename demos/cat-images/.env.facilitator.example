FACI_S3_BUCKET=cat-images
FACI_S3_ACCESS_KEY=minioadmin
FACI_S3_SECRET_KEY=minioadmin
FACI_VALIDATORS={"my-vali": "http://localhost:8081/cat-images"}

### Optional
## Set endpoint URL for S3-compatible services (MinIO, etc.). Omit for AWS S3.
# FACI_S3_ENDPOINT_URL=http://localhost:9000
# FACI_S3_REGION=
# FACI_PORT=8080
# FACI_HOST=0.0.0.0
# FACI_SUBMIT_MAX_RETRIES=3
# FACI_SUBMIT_TIMEOUT_SECONDS=30.0
