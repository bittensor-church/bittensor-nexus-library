### ── Pylon ──────────────────────────────────────────────────────
PYLON_BITTENSOR_NETWORK=test
PYLON_OPEN_ACCESS_TOKEN=local-open-access-token
PYLON_RECENT_OBJECTS_NETUIDS=[1]
# Identity used by validator for write operations (weights).
PYLON_IDENTITIES=["validator"]
PYLON_ID_VALIDATOR_WALLET_NAME=some-wallet-name
PYLON_ID_VALIDATOR_HOTKEY_NAME=default
PYLON_ID_VALIDATOR_NETUID=1
PYLON_ID_VALIDATOR_TOKEN=replace-with-strong-shared-token

### ── Validator ──────────────────────────────────────────────────
VALIDATOR_NETUID=1
VALIDATOR_OPENROUTER_API_KEY=sk-or-...
# VALIDATOR_OPENROUTER_MODEL=google/gemini-2.5-flash-image
VALIDATOR_PYLON_OPEN_ACCESS_TOKEN=local-open-access-token
VALIDATOR_PYLON_IDENTITY_NAME=validator
VALIDATOR_PYLON_IDENTITY_TOKEN=replace-with-strong-shared-token
VALIDATOR_S3_BUCKET=...

## AWS credentials — used by validator's S3PresignedUrlCreator (boto3) and facilitator's S3 uploads.
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_DEFAULT_REGION=...

### ── Miner ──────────────────────────────────────────────────────
MINER_OPENROUTER_API_KEY=sk-or-...
MINER_HOTKEY_NAME=...
#MINER_OPENROUTER_MODEL=google/gemini-2.5-flash-image
MINER_UPDATE_AXON=false

### ── Facilitator ────────────────────────────────────────────────
# FACI_S3_REGION=...
FACI_S3_BUCKET=...
FACI_S3_ACCESS_KEY=...
FACI_S3_SECRET_KEY=...
